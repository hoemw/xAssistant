# Normalize line endings for text files
* text=auto eol=lf
# Keep Visual Studio files with CRLF
*.sln text eol=crlf
*.vcxproj text eol=crlf
*.vcxproj.filters text eol=crlf
*.vcxproj.user text eol=crlf
*.csproj text eol=crlf
# Treat Unreal assets as binary and (optionally) LFS
*.uasset filter=lfs diff=lfs merge=lfs -text
*.umap filter=lfs diff=lfs merge=lfs -text
*.ubulk filter=lfs diff=lfs merge=lfs -text
*.ufont filter=lfs diff=lfs merge=lfs -text
*.upack filter=lfs diff=lfs merge=lfs -text
*.utexture filter=lfs diff=lfs merge=lfs -text
*.uplugin binary
*.uproject text eol=lf
# Common binary formats
*.png binary
*.jpg binary
*.jpeg binary
*.bmp binary
*.tga binary
*.gif binary
*.wav binary
*.ogg binary
*.mp3 binary
*.mp4 binary
*.mov binary
*.zip binary
*.7z binary
*.rar binary
*.pdf binary
